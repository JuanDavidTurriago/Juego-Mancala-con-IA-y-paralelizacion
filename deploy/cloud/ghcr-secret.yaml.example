# Plantilla: NO aplicar este archivo directamente (contiene placeholder).
# Crear el secret en el cluster cloud antes de los Deployments:
#
# kubectl create secret docker-registry ghcr-credentials \
#   --docker-server=ghcr.io \
#   --docker-username=<GITHUB_USER> \
#   --docker-password=<PAT_con_read:packages> \
#   --namespace=default
#
# Las imagenes ghcr.io/juandavidturriago/mancala-* son privadas; sin este secret
# los pods quedan en ImagePullBackOff.
#
# Verificar pull desde una maquina con el PAT:
#   echo $PAT | docker login ghcr.io -u <GITHUB_USER> --password-stdin
#   docker pull ghcr.io/juandavidturriago/mancala-motor:<SHA>
