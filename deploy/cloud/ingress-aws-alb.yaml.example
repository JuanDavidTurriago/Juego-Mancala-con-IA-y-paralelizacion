# Ejemplo alternativo: AWS Load Balancer Controller (ALB), no NGINX.
# Requiere instalar aws-load-balancer-controller en el cluster EKS.
#
# apiVersion: networking.k8s.io/v1
# kind: Ingress
# metadata:
#   name: mancala
#   annotations:
#     alb.ingress.kubernetes.io/scheme: internet-facing
#     alb.ingress.kubernetes.io/target-type: ip
#     alb.ingress.kubernetes.io/listen-ports: '[{"HTTP": 80}, {"HTTPS": 443}]'
#     alb.ingress.kubernetes.io/ssl-redirect: "443"
# spec:
#   ingressClassName: alb
#   rules:
#     - host: mancala.example.edu.co
#       http:
#         paths:
#           - path: /
#             pathType: Prefix
#             backend:
#               service:
#                 name: frontend
#                 port:
#                   number: 80
#     - host: api.mancala.example.edu.co
#       http:
#         paths:
#           - path: /
#             pathType: Prefix
#             backend:
#               service:
#                 name: backend
#                 port:
#                   number: 8000
