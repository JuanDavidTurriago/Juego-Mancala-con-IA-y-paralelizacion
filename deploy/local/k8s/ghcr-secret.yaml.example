# Copiar a ghcr-secret.yaml (no commitear tokens) o crear el secret con kubectl:
#
# kubectl create secret docker-registry ghcr-credentials \
#   --docker-server=ghcr.io \
#   --docker-username=<GITHUB_USER> \
#   --docker-password=<GITHUB_PAT con read:packages>
#
# El PAT debe tener alcance read:packages para pull de imágenes privadas en GHCR.
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-credentials
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: REPLACE_WITH_BASE64_DOCKER_CONFIG
